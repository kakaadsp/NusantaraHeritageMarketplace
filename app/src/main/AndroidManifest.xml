<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for loading images via Glide -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 11+ (API 30): Deklarasi package visibility untuk Implicit Intent -->
    <!-- Diperlukan agar resolveActivity() bisa mendeteksi Google Maps & Browser -->
    <queries>
        <!-- Google Maps -->
        <package android:name="com.google.android.apps.maps" />
        <!-- Browser (ACTION_VIEW dengan http/https) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
    </queries>


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NusantaraHeritageMarketplace"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Main Activity (Halaman Utama) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Detail Activity (Halaman Detail) -->
        <activity
            android:name=".DetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="@string/detail_title">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".MainActivity" />
        </activity>

    </application>

</manifest>